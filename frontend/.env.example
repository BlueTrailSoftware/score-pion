# Score Pion — Frontend Configuration
#
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
#

# ─── API ───────────────────────────────────────────────────
API_URL=http://localhost:7070

# ─── Google OAuth ──────────────────────────────────────────
GOOGLE_SSO_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── reCAPTCHA v3 ──────────────────────────────────────────
RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# ─── Company Branding ──────────────────────────────────────
COMPANY_NAME=Your Company Name
COMPANY_URL=https://yourcompany.com
COMPANY_LEGAL_NAME=Your Legal Entity Name
SHOW_COMPANY_LOGO=false
COMPANY_LOGO_PATH=assets/images/logos/company-logo.svg

# ─── Careers Page ──────────────────────────────────────────
CAREERS_TITLE=Join Our Team
CAREERS_SUBTITLE=Discover your next career opportunity with us

# ─── Privacy Policy ────────────────────────────────────────
PRIVACY_CONTACT_EMAIL=privacy@yourcompany.com
PRIVACY_DATA_RETENTION_MONTHS=9
