# Score Pion — Production Configuration
#
# This file is a TEMPLATE for production deployments.
# DO NOT commit actual credentials — use a secrets management system (GitHub Secrets, AWS Secrets Manager, etc.)
#
# Copy and fill in with real production values, then deploy via CI/CD or your orchestrator.
#

# ─── Environment & Debug ───────────────────────────────────
ENVIRONMENT=production
APP_DEBUG_ENABLED=false
LOG_LEVEL=WARN

# ─── AWS / DynamoDB ────────────────────────────────────────
# Use AWS DynamoDB (not local)
AWS_REGION=us-east-1
AWS_DYNAMODB_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── S3 / AWS S3 ───────────────────────────────────────────
# Use AWS S3 (not MinIO)
AWS_ENDPOINT_URL_S3=
AWS_S3_FORCE_PATH_STYLE=false
AWS_S3_FILES_ENDPOINT=https://your-s3-bucket.s3.amazonaws.com
AWS_S3_BUCKET_NAME=score-pion-uploads

# ─── SMTP (via Brevo or similar) ────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Score Pion
ADMIN_EMAIL=

# ─── App ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ─── JWT ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRATION=86400000

# ─── Google OAuth / SSO ────────────────────────────────────
# Production Google OAuth client ID for yourdomain.com
GOOGLE_CLIENT_ID=

# ─── Auth0 (if using Auth0 instead of Google OAuth) ────────
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_REDIRECT_URI=https://yourdomain.com/callback
AUTH0_REQUIRE_EMAIL_VERIFICATION=true
AUTH0_WEBHOOK_SECRET=

# ─── Google reCAPTCHA v3 ───────────────────────────────────
# Production site key and secret (keys specific to yourdomain.com)
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

# ─── Coderbyte (Assessment Provider) ───────────────────────
CODERBYTE_API_TOKEN=

# ─── Asana (Ticket Manager) ────────────────────────────────
TICKET_MANAGER_TOKEN=
TICKET_MANAGER_PROJECT_ID=
TICKET_MANAGER_WORKSPACE_ID=
TICKET_MANAGER_API_URL=https://api.asana.com/1.0

# ─── Google Chat Webhooks ────────────────────────────────────
GCHAT_INTERNAL_WEBHOOK_URL=
GCHAT_EXTERNAL_WEBHOOK_URL=

# ─── Deployment (for CI/CD) ────────────────────────────────
SCORE_PION_SERVER_PEM=
SCORE_PION_SERVER_HOST=
