# Score Pion — Backend Configuration
#
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
#
# For Docker Compose: place this file at backend/.env
# For standalone backend: place this file at backend/.env and add to your IDE/shell environment
#

# ─── Environment & Debug ───────────────────────────────────
ENVIRONMENT=local
APP_DEBUG_ENABLED=false
LOG_LEVEL=INFO

# ─── AWS / DynamoDB ────────────────────────────────────────
AWS_REGION=us-east-1
AWS_DYNAMODB_ENDPOINT=http://dynamodb-local:8000
AWS_ACCESS_KEY_ID=local-key
AWS_SECRET_ACCESS_KEY=local-secret

# ─── S3 / MinIO ────────────────────────────────────────────
# MinIO credentials (for MinIO container initialization)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MinIO endpoint and bucket configuration
AWS_ENDPOINT_URL_S3=http://minio:9000
AWS_S3_FORCE_PATH_STYLE=true
AWS_S3_FILES_ENDPOINT=http://localhost:9000/score-pion-files
AWS_S3_BUCKET_NAME=score-pion-files

# ─── SMTP ──────────────────────────────────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=test
SMTP_PASSWORD=test
EMAIL_FROM=noreply@localhost
EMAIL_FROM_NAME=Score Pion Local
ADMIN_EMAIL=admin@localhost

# ─── App ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000
FRONTEND_URL=http://localhost:4200
APP_BASE_URL=http://localhost:4200

# ─── JWT ────────────────────────────────────────────────────
# For local dev, any value works. In production, use: openssl rand -base64 32
JWT_SECRET=local-dev-secret-key-minimum-32-characters-long-xxx
JWT_EXPIRATION=86400000

# ─── Google OAuth / SSO ────────────────────────────────────
# Use dummy values for local testing
GOOGLE_CLIENT_ID=local-test-client-id.apps.googleusercontent.com

# ─── Auth0 (optional) ──────────────────────────────────────
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_REDIRECT_URI=
AUTH0_REQUIRE_EMAIL_VERIFICATION=
AUTH0_WEBHOOK_SECRET=

# ─── Google reCAPTCHA v3 ───────────────────────────────────
# Use dummy values for local testing
RECAPTCHA_SECRET_KEY=local-test-secret
RECAPTCHA_SITE_KEY=local-test-site-key

# ─── Coderbyte (Assessment Provider) ───────────────────────
# Use dummy token for local testing
CODERBYTE_API_TOKEN=local-test-coderbyte-token

# ─── Asana (Ticket Manager) ────────────────────────────────
# Use dummy token for local testing
TICKET_MANAGER_TOKEN=local-test-asana-token
TICKET_MANAGER_PROJECT_ID=
TICKET_MANAGER_WORKSPACE_ID=
TICKET_MANAGER_API_URL=

# ─── Google Chat Webhooks ────────────────────────────────────
# Use dummy URLs for local testing
GCHAT_INTERNAL_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/test-internal
GCHAT_EXTERNAL_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/test-external

# ─── Deployment (for CI/CD) ────────────────────────────────
SCORE_PION_SERVER_PEM=
SCORE_PION_SERVER_HOST=
